      "name": "LookFrom3DObjectEyes",
      "sentence": "Move the camera of _PARAM3_ to look though _PARAM1_ eyes",
      "events": [
        {
          "type": "BuiltinCommonInstructions::Standard",
          "conditions": [],
          "actions": [
