    {
      "description": "Move the camera to look through the object eyes with optional smoothing, offsets and pitch clamping.",
      "fullName": "Look through object eyes (advanced)",
      "functionType": "Action",
      "group": "Layers and cameras",
      "name": "LookFrom3DObjectEyesAdvanced",
      "sentence": "Move camera of _PARAM3_ to look through _PARAM1_ eyes (position responsiveness: _PARAM4_, rotation responsiveness: _PARAM5_)",
      "events": [
        {
          "type": "BuiltinCommonInstructions::JsCode",
          "inlineCode": [
            "const object = eventsFunctionContext.getObjects(\"Object\")[0];",
            "if (!object) return;",
            "",
            "const layerName = eventsFunctionContext.getArgument(\"Layer\");",
            "const runtimeLayer = runtimeScene.getLayer(layerName);",
            "if (!runtimeLayer) return;",
            "const layerRenderer = runtimeLayer.getRenderer();",
            "if (!layerRenderer || !layerRenderer.getThreeCamera) return;",
            "const threeCamera = layerRenderer.getThreeCamera();",
            "if (!threeCamera) return;",
            "",
            "const elapsedTime = Math.max(0, runtimeScene.getElapsedTime() / 1000);",
            "const blendFromResponsiveness = responsiveness => {",
            "  if (!Number.isFinite(responsiveness) || responsiveness <= 0) return 1;",
            "  return 1 - Math.exp(-responsiveness * elapsedTime);",
            "};",
            "",
            "const positionResponsiveness = Number(eventsFunctionContext.getArgument(\"PositionResponsiveness\"));",
            "const rotationResponsiveness = Number(eventsFunctionContext.getArgument(\"RotationResponsiveness\"));",
            "const eyeHeightOffset = Number(eventsFunctionContext.getArgument(\"EyeHeightOffset\"));",
            "const eyeForwardOffset = Number(eventsFunctionContext.getArgument(\"EyeForwardOffset\"));",
            "let minPitch = Number(eventsFunctionContext.getArgument(\"MinPitch\"));",
            "let maxPitch = Number(eventsFunctionContext.getArgument(\"MaxPitch\"));",
            "",
            "if (!Number.isFinite(minPitch)) minPitch = -89;",
            "if (!Number.isFinite(maxPitch)) maxPitch = 89;",
            "if (minPitch > maxPitch) {",
            "  const previousMinPitch = minPitch;",
            "  minPitch = maxPitch;",
            "  maxPitch = previousMinPitch;",
            "}",
            "",
            "const objectAngle = Number.isFinite(object.getAngle()) ? object.getAngle() : 0;",
            "const objectRotationX =",
            "  typeof object.getRotationX === \"function\" && Number.isFinite(object.getRotationX())",
            "    ? object.getRotationX()",
            "    : 0;",
            "const objectRotationY =",
            "  typeof object.getRotationY === \"function\" && Number.isFinite(object.getRotationY())",
            "    ? object.getRotationY()",
            "    : 0;",
            "",
            "const targetX =",
            "  object.getCenterXInScene() +",
            "  Math.cos(gdjs.toRad(objectAngle)) *",
            "    (Number.isFinite(eyeForwardOffset) ? eyeForwardOffset : 0);",
            "const targetY =",
            "  object.getCenterYInScene() +",
            "  Math.sin(gdjs.toRad(objectAngle)) *",
            "    (Number.isFinite(eyeForwardOffset) ? eyeForwardOffset : 0);",
            "const targetZ =",
            "  (typeof object.getZ === \"function\" ? object.getZ() : 0) +",
            "  (Number.isFinite(eyeHeightOffset) ? eyeHeightOffset : 0);",
            "",
            "const cameraIndex = 0;",
            "const positionBlend = blendFromResponsiveness(positionResponsiveness);",
            "const rotationBlend = blendFromResponsiveness(rotationResponsiveness);",
            "",
            "const currentCameraX = runtimeLayer.getCameraX(cameraIndex);",
            "const currentCameraY = runtimeLayer.getCameraY(cameraIndex);",
            "const currentCameraZ = gdjs.scene3d.camera.getCameraZ(",
            "  runtimeScene,",
            "  layerName,",
            "  cameraIndex",
            ");",
            "const blendedCameraX = gdjs.evtTools.common.lerp(currentCameraX, targetX, positionBlend);",
            "const blendedCameraY = gdjs.evtTools.common.lerp(currentCameraY, targetY, positionBlend);",
            "const blendedCameraZ = gdjs.evtTools.common.lerp(currentCameraZ, targetZ, positionBlend);",
            "",
            "runtimeLayer.setCameraX(blendedCameraX, cameraIndex);",
            "runtimeLayer.setCameraY(blendedCameraY, cameraIndex);",
            "gdjs.scene3d.camera.setCameraZ(runtimeScene, blendedCameraZ, layerName, cameraIndex);",
            "",
            "const targetPitch = gdjs.evtTools.common.clamp(",
            "  -objectRotationY + 90,",
            "  minPitch,",
            "  maxPitch",
            ");",
            "const targetYaw = objectRotationX;",
            "const targetRoll = objectAngle + 90;",
            "",
            "const currentPitch = gdjs.scene3d.camera.getCameraRotationX(",
            "  runtimeScene,",
            "  layerName,",
            "  cameraIndex",
            ");",
            "const currentYaw = gdjs.scene3d.camera.getCameraRotationY(",
            "  runtimeScene,",
            "  layerName,",
            "  cameraIndex",
            ");",
            "const currentRoll = runtimeLayer.getCameraRotation(cameraIndex);",
            "",
            "const lerpAngle = (from, to, blend) =>",
            "  from + gdjs.evtTools.common.angleDifference(to, from) * blend;",
            "",
            "const blendedPitch = lerpAngle(currentPitch, targetPitch, rotationBlend);",
            "const blendedYaw = lerpAngle(currentYaw, targetYaw, rotationBlend);",
            "const blendedRoll = lerpAngle(currentRoll, targetRoll, rotationBlend);",
            "",
            "gdjs.scene3d.camera.setCameraRotationX(",
            "  runtimeScene,",
            "  blendedPitch,",
            "  layerName,",
            "  cameraIndex",
            ");",
            "gdjs.scene3d.camera.setCameraRotationY(",
            "  runtimeScene,",
            "  blendedYaw,",
            "  layerName,",
            "  cameraIndex",
            ");",
            "runtimeLayer.setCameraRotation(blendedRoll, cameraIndex);"
          ],
          "parameterObjects": "",
          "useStrict": true
        }
      ],
      "parameters": [
        {
          "description": "3D Object",
          "name": "Object",
          "type": "objectList"
        },
        {
          "description": "3D capability",
          "name": "Object3D",
          "supplementaryInformation": "Scene3D::Base3DBehavior",
          "type": "behavior"
        },
        {
          "description": "Layer",
          "name": "Layer",
          "type": "layer"
        },
        {
          "description": "Position responsiveness (0 = instant, higher = smoother)",
          "name": "PositionResponsiveness",
          "type": "expression"
        },
        {
          "description": "Rotation responsiveness (0 = instant, higher = smoother)",
          "name": "RotationResponsiveness",
          "type": "expression"
        },
        {
          "description": "Eye height offset",
          "name": "EyeHeightOffset",
          "type": "expression"
        },
        {
          "description": "Eye forward offset",
          "name": "EyeForwardOffset",
          "type": "expression"
        },
        {
          "description": "Minimum camera pitch",
          "name": "MinPitch",
          "type": "expression"
        },
        {
          "description": "Maximum camera pitch",
          "name": "MaxPitch",
          "type": "expression"
        }
      ],
      "objectGroups": []
    }
  ],
